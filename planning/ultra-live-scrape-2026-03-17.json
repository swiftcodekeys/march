{
  "scraped": "2026-03-17 via Playwright from https://www.ultrafence.com/design-studio/gates/index.html",
  "threeVersion": "r86",

  "camera": {
    "type": "PerspectiveCamera",
    "fov": 40,
    "zoom": 1.788,
    "near": 1,
    "far": 100,
    "position": { "x": 0.82, "y": 1.27, "z": 7.2 },
    "rotation": { "x": 0, "y": 6, "z": 0, "order": "YXZ" },
    "note": "rotation.y is 6 degrees (0.10472 radians)"
  },

  "renderer": {
    "shadowMapEnabled": false,
    "toneMapping": 1,
    "toneMappingNote": "1 = LinearToneMapping (default, NO fancy tone mapping)",
    "toneMappingExposure": 1,
    "gammaOutput": false,
    "gammaFactor": 2,
    "gammaInput": false,
    "localClippingEnabled": true,
    "alpha": true,
    "pixelRatio": 1,
    "clearColor": 0,
    "clearAlpha": 0
  },

  "lights": [
    {
      "type": "AmbientLight",
      "color": "0xffffff",
      "intensity": 0.5,
      "note": "ONLY light in the scene — no directional, no shadows"
    }
  ],

  "materials": {
    "type": "MeshStandardMaterial",
    "shading": 1,
    "shadingNote": "1 = FlatShading — Ultra DOES use FlatShading",
    "side": 0,
    "sideNote": "0 = FrontSide",
    "transparent": false,
    "opacity": 1,
    "hasEnvMap": true,
    "envMapNote": "PMREM-processed HDR, mapping=306 (CubeUVReflectionMapping)",
    "hasBumpMap": true,
    "bumpMapNote": "2048x2048, generated on Canvas element (not loaded directly from file)",
    "hasAoMap": false,
    "hasNormalMap": false,
    "hasRoughnessMap": false,
    "hasMetalnessMap": false,
    "castShadow": false,
    "receiveShadow": false
  },

