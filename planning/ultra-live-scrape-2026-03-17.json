    "source": "HDR cube map processed via PMREMGenerator + PMREMCubeUVPacker",
    "hdrFiles": "gate_tool/t/hdr/px.hdr, nx.hdr, py.hdr, ny.hdr, pz.hdr, nz.hdr",
    "loaders": ["RGBELoader.js", "PMREMGenerator.js", "PMREMCubeUVPacker.js", "HDRCubeTextureLoader.js"]
  },

  "bumpMap": {
    "globalVar": "bImg",
    "size": "2048x2048",
